{
  "name": "semver-es",
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "description": "Modern ESM-first TypeScript rewrite of npm's semver.",
  "author": "jinghaihan",
  "license": "MIT",
  "homepage": "https://github.com/jinghaihan/semver-es#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jinghaihan/semver-es.git"
  },
  "bugs": {
    "url": "https://github.com/jinghaihan/semver-es/issues"
  },
  "keywords": [
    "semver",
    "npm",
    "esm"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./classes/comparator": "./dist/classes/comparator.mjs",
    "./classes/range": "./dist/classes/range.mjs",
    "./classes/semver": "./dist/classes/semver.mjs",
    "./functions/clean": "./dist/functions/clean.mjs",
    "./functions/cmp": "./dist/functions/cmp.mjs",
    "./functions/coerce": "./dist/functions/coerce.mjs",
    "./functions/compare": "./dist/functions/compare.mjs",
    "./functions/compare-build": "./dist/functions/compare-build.mjs",
    "./functions/compare-loose": "./dist/functions/compare-loose.mjs",
    "./functions/diff": "./dist/functions/diff.mjs",
    "./functions/eq": "./dist/functions/eq.mjs",
    "./functions/gt": "./dist/functions/gt.mjs",
    "./functions/gte": "./dist/functions/gte.mjs",
    "./functions/inc": "./dist/functions/inc.mjs",
    "./functions/lt": "./dist/functions/lt.mjs",
    "./functions/lte": "./dist/functions/lte.mjs",
    "./functions/major": "./dist/functions/major.mjs",
    "./functions/minor": "./dist/functions/minor.mjs",
    "./functions/neq": "./dist/functions/neq.mjs",
    "./functions/parse": "./dist/functions/parse.mjs",
    "./functions/patch": "./dist/functions/patch.mjs",
    "./functions/prerelease": "./dist/functions/prerelease.mjs",
    "./functions/rcompare": "./dist/functions/rcompare.mjs",
    "./functions/rsort": "./dist/functions/rsort.mjs",
    "./functions/satisfies": "./dist/functions/satisfies.mjs",
    "./functions/sort": "./dist/functions/sort.mjs",
    "./functions/valid": "./dist/functions/valid.mjs",
    "./ranges/gtr": "./dist/ranges/gtr.mjs",
    "./ranges/intersects": "./dist/ranges/intersects.mjs",
    "./ranges/ltr": "./dist/ranges/ltr.mjs",
    "./ranges/max-satisfying": "./dist/ranges/max-satisfying.mjs",
    "./ranges/min-satisfying": "./dist/ranges/min-satisfying.mjs",
    "./ranges/min-version": "./dist/ranges/min-version.mjs",
    "./ranges/outside": "./dist/ranges/outside.mjs",
    "./ranges/simplify": "./dist/ranges/simplify.mjs",
    "./ranges/subset": "./dist/ranges/subset.mjs",
    "./ranges/to-comparators": "./dist/ranges/to-comparators.mjs",
    "./ranges/valid": "./dist/ranges/valid.mjs",
    "./*": "./*"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "tsx ./src/index.ts",
    "build": "tsdown",
    "deps": "taze major -I",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "release": "bumpp",
    "bootstrap": "pnpm install",
    "prepare": "simple-git-hooks",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "tsdown": "catalog:build",
    "bumpp": "catalog:dev",
    "pncat": "catalog:dev",
    "simple-git-hooks": "catalog:dev",
    "taze": "catalog:dev",
    "tsx": "catalog:dev",
    "typescript": "catalog:dev",
    "@octohash/eslint-config": "catalog:lint",
    "eslint": "catalog:lint",
    "lint-staged": "catalog:lint",
    "vitest": "catalog:test",
    "@types/node": "catalog:types"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
